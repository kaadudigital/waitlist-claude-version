{% comment %}theme-check-disable MissingTemplate{% endcomment %}
{%- liquid
  if display_on_card
    assign desktop_sizes_base = 'calc(100vw - 5rem)'
    assign mobile_sizes_base = 'calc(100vw - 2.5rem)'
  else
    assign desktop_sizes_base = '100vw'
    assign mobile_sizes_base = '100vw'
  endif

  case image_size
    when 'third'
      assign text_width_desktop = 'lg:col-span-8'
      assign desktop_sizes = 'calc(' | append: desktop_sizes_base | append: ' / 3)'

      if image_position == 'right'
        assign image_width_desktop = 'lg:col-start-9 lg:col-end-13 '
      else
        assign image_width_desktop = 'lg:col-span-4'
      endif
    when 'three_fifths'
      assign text_width_desktop = 'lg:col-span-5'
      assign desktop_sizes = 'calc((' | append: desktop_sizes_base | append: ' / 12) * 7)'

      if image_position == 'right'
        assign image_width_desktop = 'lg:col-start-6 lg:col-end-13'
      else
        assign image_width_desktop = 'lg:col-span-7'
      endif
    when 'two_thirds'
      assign text_width_desktop = 'lg:col-span-4'
      assign desktop_sizes = 'calc((' | append: desktop_sizes_base | append: ' / 12) * 8)'

      if image_position == 'right'
        assign image_width_desktop = 'lg:col-start-5 lg:col-end-13'
      else
        assign image_width_desktop = 'lg:col-span-8'
      endif
  endcase

  assign mobile_sizes = mobile_sizes_base

  assign sizes = '(min-width: 990px) ' | append: desktop_sizes | append: ', ' | append: mobile_sizes

  unless loading
    assign loading = 'lazy'

    if section.index <= 3
      assign loading = 'eager'
    endif
  endunless

  unless preload
    assign preload = false
  endunless

  # Handle text alignment for mobile vs desktop
  if mobile_text_alignment != blank
    assign mobile_text_class = mobile_text_alignment
  else
    assign mobile_text_class = text_alignment
  endif

  # Combine desktop and mobile text alignment classes
  assign combined_text_alignment = mobile_text_class | append: ' sm:' | append: text_alignment | append: ' lg:' | append: text_alignment | append: ' xl:' | append: text_alignment | append: ' 2xl:' | append: text_alignment
  # Handle mobile layout order
  if mobile_layout_order
    assign mobile_heading_order = 'order-1'
    assign mobile_image_order = 'order-2'
    assign mobile_text_order = 'order-3'
    assign mobile_button_order = 'order-4'
  else
    assign mobile_heading_order = ''
    assign mobile_image_order = ''
    assign mobile_text_order = ''
    assign mobile_button_order = ''
  endif
-%}

{%- render 'shape-defs', shape: image_shape, shape_id: section_id, index: index, blob_type: blob_type -%}

<div class="relative z-10 mx-auto max-w-site px-section">
  <div class="{% if display_on_card %}card{% endif %}">
    <div class="{% if display_on_card %}card__surface p-5 lg:p-10{% endif %} section-content relative z-10 mx-auto">
      <div class="grid grid-flow-row-dense grid-cols-1 gap-4 lg:grid-cols-12 {% if image_size == 'half' and image_position == 'right' %}reverse-flex-half{% elsif image_size == 'half' %}normal-flex-half{% endif %}">
        {%- comment -%} Mobile Layout when mobile_layout_order is enabled {%- endcomment -%}
        {%- if mobile_layout_order -%}
          {%- comment -%} Mobile: Heading first {%- endcomment -%}
          <div style="margin: auto;" class="col-span-1 lg:hidden {{ mobile_heading_order }}">
            {% if title != '' %}
              <h2 class="inline-heading-rte font-subheading {{ heading_size }} heading-style {{ settings.heading_drop_shadow_style }} break-words {{ combined_text_alignment }} custom-section-headline custom-display-header ">
                {{ title }}
              </h2>
            {% endif %}
          </div>

          {%- comment -%} Image column - responsive to both mobile order and desktop position {%- endcomment -%}
          <div
            style="max-width: 600px; max-height: 660px; "
            class=" mx-auto lg:mx-0  {{ image_width_desktop }} {{ mobile_image_order }}"
          >
            {%- if image != blank -%}
              {%- render 'media-image',
                media: image,
                shape_id: section_id,
                shape: image_shape,
                crop: crop,
                rotate: rotate_image,
                is_card: display_on_card,
                container_id: container_id,
                disable_media_style: disable_media_style,
                loading: loading,
                preload: preload,
                sizes: sizes
              -%}
            {%- else -%}
              {%- render 'media-image-placeholder',
                shape_id: section_id,
                container_id: section_id,
                shape: image_shape,
                crop: crop,
                rotate: rotate_image,
                is_card: display_on_card,
                blob_type: blob_type,
                disable_media_style: disable_media_style
              -%}
            {%- endif -%}
          </div>

          {%- comment -%} Text content column {%- endcomment -%}
          <div class="flex items-center {{ text_width_desktop }} {% if image_size == 'half'%}min-width-on-lg-screen{% endif %}">
            <div class="w-full center-flex-column-custom">
              {%- comment -%} Desktop: Heading shown here {%- endcomment -%}
              <div style="margin: auto;" class="hidden lg:block">
                {% if title != '' %}
                  <h2 class="inline-heading-rte font-subheading {{ heading_size }} heading-style {{ settings.heading_drop_shadow_style }} break-words {{ combined_text_alignment }} custom-section-headline custom-display-header">
                    {{ title }}
                  </h2>
                {% endif %}
              </div>

              {%- comment -%} Mobile: Text content {%- endcomment -%}
              {% comment %} <div class="rte mt-5 max-w-2xl {{ combined_text_alignment }} {{ mobile_text_order }} {% if text_alignment contains 'center' %}lg:mx-auto{% elsif text_alignment contains 'right' %}lg:ml-auto{% endif %} {% if mobile_text_alignment contains 'center' %}mx-auto lg:mx-0{% elsif mobile_text_alignment contains 'right' %}ml-auto lg:ml-0{% endif %}"> {% endcomment %}
              <div class="rte    max-w-2xl {{ mobile_text_order }} {{ combined_text_alignment }} lg:mt-6 mt-3 custom-body-xlarge">
                {{ richtext }}
              </div>
              <div class=" mt-5 flex items-center custom-image-with-text-button-wrapper {{ mobile_button_order }} {{ combined_text_alignment }} lgmt-8  ">
                {%- if button2_link_type == 'url' and button2_link != blank and button_label != '' -%}
                  <div class="mt-5">
                    <a href="{{ button_link }}">
                      <button class="custom-shape-button">
                        <span class="custom-shape-button-text">
                          {{ button2_label }}
                        </span>
                      </button>
                    </a>
                  </div>
                {%- endif -%}
                {%- if button2_link_type == 'focus_element' and focus_element_id != blank -%}
                  <div class=" mt-5 lg:mt-6 custom-btn-wrapper">
                    <button
                      onclick="console.log('Focus Element ID: {{ focus_element2_id }}'); document.getElementById('{{focus_element2_id}}')?.focus()"
                      class="inline-block custom-btn custom-shape-button"
                    >
                      <span class="custom-shape-button-text">
                        {{ button2_label }}
                      </span>
                    </button>
                  </div>
                {%- endif -%}
                {%- if button_link_type == 'url' and button_link != blank and button_label != '' -%}
                  <div class="mt-5">
                    <a href="{{ button_link }}" class=" inline-block custom-btn">
                      <span class="push-btn__surface custom-btn__surface">{{ button_label }}</span>
                    </a>
                  </div>
                {%- endif -%}
                {%- if button_link_type == 'focus_element' and focus_element_id != blank -%}
                  <div class=" mt-5 lg:mt-6 custom-btn-wrapper">
                    <button
                      onclick="console.log('Focus Element ID: {{ focus_element_id }}'); document.getElementById('{{focus_element_id}}')?.focus()"
                      class="inline-block custom-btn"
                    >
                      <span class="push-btn__surface custom-btn__surface custom-button-text">{{ button_label }}</span>
                    </button>
                  </div>
                {%- endif -%}
              </div>
            </div>
          </div>

        {%- else -%}
          {%- comment -%} Default layout when mobile_layout_order is disabled {%- endcomment -%}
          <div style="max-width: 600px; max-height: 660px; " class="{{ image_width_desktop }}">
            {%- if image != blank -%}
              {%- render 'media-image',
                media: image,
                shape_id: section_id,
                shape: image_shape,
                crop: crop,
                rotate: rotate_image,
                is_card: display_on_card,
                container_id: container_id,
                disable_media_style: disable_media_style,
                loading: loading,
                preload: preload,
                sizes: sizes
              -%}
            {%- else -%}
              {%- render 'media-image-placeholder',
                shape_id: section_id,
                container_id: section_id,
                shape: image_shape,
                crop: crop,
                rotate: rotate_image,
                is_card: display_on_card,
                blob_type: blob_type,
                disable_media_style: disable_media_style
              -%}
            {%- endif -%}
          </div>

          <div class="flex items-center {{ text_width_desktop }} {% if image_size == 'half'%}min-width-on-lg-screen{% endif %} ">
            <div style="margin: auto;" class="w-full center-flex-column-custom ">
              {% if title != '' %}
                <h2 class="inline-heading-rte font-subheading {{ heading_size }} heading-style {{ settings.heading_drop_shadow_style }} break-words {{ combined_text_alignment }} custom-section-headline custom-display-header ">
                  {{ title }}
                </h2>
              {% endif %}

              {% comment %} <div class="rte mt-5 max-w-2xl {{ combined_text_alignment }} {% if text_alignment contains 'center' %}lg:mx-auto{% elsif text_alignment contains 'right' %}lg:ml-auto{% endif %} {% if mobile_text_alignment contains 'center' %}mx-auto lg:mx-0{% elsif mobile_text_alignment contains 'right' %}ml-auto lg:ml-0{% endif %}"> {% endcomment %}
              <div class="rte   max-w-2xl {{ combined_text_alignment }} lg:mt-6 mt-3 custom-body-xlarge ">
                {{ richtext }}
              </div>

              <div class=" mt-5 flex  items-center custom-image-with-text-button-wrapper {{ combined_text_alignment }} lgmt-8  ">
                {%- if button2_link_type == 'url' and button2_link != blank and button_label != '' -%}
                  <div class="mt-5">
                    <a href="{{ button_link }}">
                      <button class="custom-shape-button">
                        <span class="push-btn__surface custom-btn__surface custom-shape-button-text">
                          {{- button_label -}}
                        </span>
                      </button>
                    </a>
                  </div>
                {%- endif -%}
                {%- if button2_link_type == 'focus_element' and focus_element_id != blank -%}
                  <div class=" mt-5 lg:mt-6 custom-btn-wrapper">
                    <button
                      onclick="console.log('Focus Element ID: {{ focus_element2_id }}'); document.getElementById('{{focus_element2_id}}')?.focus()"
                      class="inline-block custom-btn custom-shape-button"
                    >
                      <span class="push-btn__surface custom-btn__surface custom-shape-button-text">
                        {{- button_label -}}
                      </span>
                    </button>
                  </div>
                {%- endif -%}
                {%- if button_link_type == 'url' and button_link != blank and button_label != '' -%}
                  <div class="mt-5">
                    <a href="{{ button_link }}" class=" inline-block custom-btn">
                      <span class="push-btn__surface custom-btn__surface">{{ button_label }}</span>
                    </a>
                  </div>
                {%- endif -%}
                {%- if button_link_type == 'focus_element' and focus_element_id != blank -%}
                  <div class=" mt-5 lg:mt-6 custom-btn-wrapper">
                    <button
                      onclick="console.log('Focus Element ID: {{ focus_element_id }}'); document.getElementById('{{focus_element_id}}')?.focus()"
                      class="inline-block custom-btn"
                    >
                      <span class="push-btn__surface custom-btn__surface custom-button-text">{{ button_label }}</span>
                    </button>
                  </div>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
<style>
    .custom-image-with-text-button-wrapper {
      flex-direction: row;
      gap: 20px
    }
    @media (max-width: 768px) {
      .custom-image-with-text-button-wrapper {
        flex-direction: column;
      }
    }


    .center-flex-column-custom {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .custom-shape-button {
          background-size: contain;
          background-position: center;
          background-repeat: no-repeat;
          border: none;
          cursor: pointer;
          transition: transform 0.3s ease;
          position: relative;
          display: flex;
          align-items: center;
          justify-content: center;
          background-image: url('{{ section.settings.button2_image | img_url: 'master' }}');
    }
  .custom-shape-button-text {
          color: #AE0000;
          font-family: fagies;
          font-size: 24px;
          font-weight: 400;
          padding: {{  section.settings.button2_padding_topbottom }}px 24px;
        }

    @media (min-width: 1024px) {
      .normal-flex-half {
        display: flex;
        justify-content: center;
        gap: 1.5rem; /* 24px - lg:gap-6 */
      }
      .min-width-on-lg-screen {
        min-width: 460px;
      }

      .reverse-flex-half {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        flex-direction: row-reverse;
      }
    }

    @media (min-width: 1280px) {
      .normal-flex-half,
      .reverse-flex-half {
        gap: 2rem; /* 32px - xl:gap-8 */
      }
    }
</style>
