{%- liquid
  assign border_classes = 'border-t-section border-section-border'
-%}

{%- style -%}
  #{{ section.id }} .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  #{{ section.id }} .footer-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  #{{ section.id }} .footer-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  #{{ section.id }} .social-icon {
    width: 24px;
    height: 24px;
  }

  #{{ section.id }} .custom-svg-size {
    width: 15px;
    height: 15px;
  }

  @media (min-width: 990px) {
    #{{ section.id }} .footer-content {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
    #{{ section.id }} .social-icon {
      width: 32px;
      height: 32px;
    }

    #{{ section.id }} .custom-svg-size {
    width: 16px;
    height: 16px;
  }


    #{{ section.id }} .footer-left {
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
    }
  }
{%- endstyle -%}

<footer
  id="{{ section.id }}"
  class="relative bg-scheme-background text-scheme-text {{ border_classes }}"
  data-color-scheme="{{ section.settings.color_scheme }}"
  role="contentinfo"
>
  <div class="section-content px-section py-section-vertical-spacing">
    <div class="mx-auto max-w-site">
      
      {%- comment -%} Desktop: Email and socials LEFT, Links RIGHT | Mobile: All centered vertically {%- endcomment -%}
      <div class="footer-content">
        
        {%- comment -%} Left side: Email and Social Icons (horizontal on desktop) {%- endcomment -%}
        <div class="footer-left">
          {%- if section.settings.email != blank -%}
            <div class="font-heading text-2xl custom-section-headline break-word">
              {{ section.settings.email }}
            </div>
          {%- endif -%}
          
          {%- comment -%} Social Icons {%- endcomment -%}
          {%- if section.settings.show_social_icons -%}
            <div class="flex items-center gap-4">
              {%- if section.settings.instagram_url != blank -%}
                <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram" class="text-scheme-text hover:opacity-70 transition-opacity">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </svg>
                </a>
              {%- endif -%}
              
              {%- if section.settings.tiktok_url != blank -%}
                <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok" class="text-scheme-text hover:opacity-70 transition-opacity">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                    <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Right side: Footer Links {%- endcomment -%}
        {%- if section.settings.show_footer_links -%}
          <div class="footer-right">
            {%- if section.settings.link_1_text != blank and section.settings.link_1_url != blank -%}
              <a href="{{ section.settings.link_1_url }}" class="flex items-center gap-2 hover:opacity-70 transition-opacity custom-body-large">
                {% comment %} <span class="text-xl custom-body-default">✱</span> {% endcomment %}
                  <svg xmlns="http://www.w3.org/2000/svg" class="custom-svg-size" viewBox="0 0 24 24" fill="currentColor">
    <path d="M23,12c0,.74-5.41.76-5.6,1.45-.19.71,4.48,3.43,4.12,4.05-.36.63-5.06-2.06-5.57-1.55s2.18,5.21,1.55,5.57c-.62.36-3.34-4.31-4.05-4.12-.69.18-.71,5.6-1.45,5.6s-.76-5.41-1.45-5.6c-.71-.19-3.43,4.48-4.05,4.12-.63-.36,2.06-5.06,1.55-5.57s-5.21,2.18-5.57,1.55c-.36-.62,4.31-3.34,4.12-4.05-.18-.69-5.6-.71-5.6-1.45s5.41-.76,5.6-1.45c.19-.71-4.48-3.43-4.12-4.05.36-.63,5.06,2.06,5.57,1.55s-2.18-5.21-1.55-5.57c.62-.36,3.34,4.31,4.05,4.12.69-.18.71-5.6,1.45-5.6s.76,5.41,1.45,5.6c.71.19,3.43-4.48,4.05-4.12.63.36-2.06,5.06-1.55,5.57s5.21-2.18,5.57-1.55c.36.62-4.31,3.34-4.12,4.05.18.69,5.6.71,5.6,1.45h0Z"/>
  </svg>
                <span>{{ section.settings.link_1_text }}</span>
              </a>
            {%- endif -%}
            
            {%- if section.settings.link_2_text != blank and section.settings.link_2_url != blank -%}
              <a href="{{ section.settings.link_2_url }}" class="flex items-center gap-2 hover:opacity-70 transition-opacity custom-body-large">
                {% comment %} <span class="text-xl custom-body-default">✱</span> {% endcomment %}
                  <svg xmlns="http://www.w3.org/2000/svg" class="custom-svg-size" viewBox="0 0 24 24" fill="currentColor">
    <path d="M23,12c0,.74-5.41.76-5.6,1.45-.19.71,4.48,3.43,4.12,4.05-.36.63-5.06-2.06-5.57-1.55s2.18,5.21,1.55,5.57c-.62.36-3.34-4.31-4.05-4.12-.69.18-.71,5.6-1.45,5.6s-.76-5.41-1.45-5.6c-.71-.19-3.43,4.48-4.05,4.12-.63-.36,2.06-5.06,1.55-5.57s-5.21,2.18-5.57,1.55c-.36-.62,4.31-3.34,4.12-4.05-.18-.69-5.6-.71-5.6-1.45s5.41-.76,5.6-1.45c.19-.71-4.48-3.43-4.12-4.05.36-.63,5.06,2.06,5.57,1.55s-2.18-5.21-1.55-5.57c.62-.36,3.34,4.31,4.05,4.12.69-.18.71-5.6,1.45-5.6s.76,5.41,1.45,5.6c.71.19,3.43-4.48,4.05-4.12.63.36-2.06,5.06-1.55,5.57s5.21-2.18,5.57-1.55c.36.62-4.31,3.34-4.12,4.05.18.69,5.6.71,5.6,1.45h0Z"/>
  </svg>
                <span>{{ section.settings.link_2_text }}</span>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

      </div>

    </div>
  </div>

  {%- comment -%} Background blocks {%- endcomment -%}
  {%- liquid
    for block in section.blocks
      case block.type
        when 'background_shape'
          render 'block-background-shape', block: block
        when 'background_pattern'
          render 'block-background-pattern', block: block, scheme: section.settings.color_scheme
      endcase
    endfor
  -%}

</footer>

{%- liquid
  assign stickers = section.blocks | where: 'type', 'sticker'
  assign shape_dividers = section.blocks | where: 'type', 'shape_divider'
  for sticker in stickers
    render 'block-sticker', block: sticker
  endfor
  for shape_divider in shape_dividers
    render 'block-shape-divider', block: shape_divider
  endfor
-%}

