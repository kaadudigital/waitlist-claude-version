{{ 'kaadu-ds.css' | asset_url | stylesheet_tag }}

{%- assign has_image = false -%}
{%- if section.settings.image != blank -%}
  {%- assign has_image = true -%}
{%- endif -%}

{%- assign img_right = false -%}
{%- if section.settings.image_position == 'right' -%}
  {%- assign img_right = true -%}
{%- endif -%}

{%- assign section_classes = 'kds-h' -%}
{%- if has_image -%}
  {%- assign section_classes = section_classes | append: ' kds-h--split' -%}
{%- endif -%}
{%- if img_right -%}
  {%- assign section_classes = section_classes | append: ' kds-h--img-right' -%}
{%- endif -%}

<section
  id="kds-hero-{{ section.id }}"
  class="{{ section_classes }}"
  style="background-color: {{ section.settings.bg_color }};"
>
  <div class="kds-h__container">

    <div class="kds-h__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="kds-h__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="kds-h__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.body_text != blank -%}
        <div class="kds-h__body">{{ section.settings.body_text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        {%- assign btn_href = '' -%}
        {%- if section.settings.button_scroll_target != blank -%}
          {%- assign btn_href = '#' | append: section.settings.button_scroll_target -%}
        {%- elsif section.settings.button_url != blank -%}
          {%- assign btn_href = section.settings.button_url -%}
        {%- endif -%}
        {%- if btn_href != '' -%}
          <a href="{{ btn_href }}" class="kds-btn kds-btn--display kds-h__cta">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- if has_image -%}
      <div class="kds-h__media" aria-hidden="true">
        <div class="kds-image-frame kds-h__frame" style="background-color: {{ section.settings.image_fallback_color }};">
          {{ section.settings.image | image_url: width: 700 | image_tag: loading: 'eager', class: 'kds-h__img', alt: '' }}
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .kds-h {
    padding: var(--kds-s16) 0 var(--kds-s12);
    min-height: 75vh;
    display: flex;
    align-items: center;
  }

  .kds-h__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--kds-s8);
    width: 100%;
  }

  .kds-h--split .kds-h__container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--kds-s12);
    align-items: center;
  }

  .kds-h--split.kds-h--img-right .kds-h__content { order: 1; }
  .kds-h--split.kds-h--img-right .kds-h__media   { order: 2; }

  .kds-h--split:not(.kds-h--img-right) .kds-h__content { order: 2; }
  .kds-h--split:not(.kds-h--img-right) .kds-h__media   { order: 1; }

  .kds-h__eyebrow {
    font-family: var(--kds-font-heading);
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kds-violet);
    margin: 0 0 var(--kds-s3);
  }

  .kds-h__heading {
    font-family: var(--kds-font-display);
    font-weight: 400;
    font-size: 64px;
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--kds-red);
    letter-spacing: -0.01em;
    margin: 0 0 var(--kds-s6);
  }

  .kds-h__body {
    font-family: var(--kds-font-body);
    font-size: 18px;
    line-height: 1.56;
    color: var(--kds-black);
    margin: 0 0 var(--kds-s8);
    max-width: 480px;
  }

  .kds-h:not(.kds-h--split) .kds-h__body {
    max-width: 680px;
  }

  .kds-h__media {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .kds-h__frame {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 1 / 1;
  }

  .kds-h__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) and (max-width: 989px) {
    .kds-h__heading { font-size: 52px; }
    .kds-h--split .kds-h__container { gap: var(--kds-s8); }
  }

  @media (max-width: 767px) {
    .kds-h {
      min-height: auto;
      padding: var(--kds-s12) 0 var(--kds-s8);
    }

    .kds-h__container,
    .kds-h--split .kds-h__container {
      display: flex;
      flex-direction: column;
      gap: var(--kds-s8);
      padding: 0 var(--kds-s6);
      text-align: center;
    }

    .kds-h__media   { order: 1; }
    .kds-h__content { order: 2; }

    .kds-h__heading { font-size: 44px; line-height: 1.05; }
    .kds-h__body    { max-width: 100%; }
    .kds-h__frame   { max-width: 240px; }

    .kds-h__cta { display: block; text-align: center; }
  }
</style>

{% schema %}
{
  "name": "KDS - Hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Gefriergetrocknete Fruechte"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "CRUNCH IN PROGRESS!"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body copy",
      "default": "<p>100% Frucht. 0% Ausbeutung. Gefriergetrocknete Fruechte; fair produziert, in der Ursprungsgemeinde verarbeitet, radikal transparent.</p>"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "WAITLIST BEITRETEN"
    },
    {
      "type": "text",
      "id": "button_scroll_target",
      "label": "Scroll-to element ID",
      "info": "ID of the page element to scroll to on click. Takes priority over Button URL.",
      "default": "kds-email-signup"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL (used when no scroll target set)"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position on desktop",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "color",
      "id": "image_fallback_color",
      "label": "Frame fill colour (shown when no image)",
      "default": "#FF781E"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#FFC5FF"
    }
  ],
  "presets": [
    {
      "name": "KDS - Hero"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
