{{ 'kaadu-ds.css' | asset_url | stylesheet_tag }}

<section
  id="kds-email-signup"
  class="kds-es"
  style="background-color: {{ section.settings.bg_color }}; padding: {{ section.settings.padding_v }}px 0;"
>
  <div class="kds-es__container">

    {%- if section.settings.heading != blank -%}
      <h2 class="kds-es__heading" style="color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <form
      method="post"
      action="/contact#contact_form"
      accept-charset="UTF-8"
      class="kds-es__form"
      id="kds-es-form-{{ section.id }}"
    >
      <input type="hidden" name="form_type" value="customer">
      <input type="hidden" name="contact[tags]" value="waitlist">
      <input type="hidden" name="utf8" value="✓">

      <div class="kds-es__row">
        <label for="kds-es-email-{{ section.id }}" class="kds-es__label">
          {{ section.settings.placeholder }}
        </label>
        <input
          type="email"
          name="contact[email]"
          id="kds-es-email-{{ section.id }}"
          class="kds-es__input"
          placeholder="{{ section.settings.placeholder }}"
          autocomplete="email"
          required
        >
        <button type="submit" class="kds-btn kds-btn--display kds-es__submit">
          {{ section.settings.button_label }}
        </button>
      </div>

    </form>

    {%- if section.settings.subtext != blank -%}
      <p class="kds-es__subtext" style="color: {{ section.settings.subtext_color }};">
        {{ section.settings.subtext }}
      </p>
    {%- endif -%}

  </div>
</section>

<style>
  .kds-es__container {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 var(--kds-s8);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--kds-s4);
  }

  .kds-es__heading {
    font-family: var(--kds-font-heading);
    font-weight: 700;
    font-size: 24px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  /* Visually hidden label — still read by screen readers */
  .kds-es__label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .kds-es__row {
    display: flex;
    gap: var(--kds-s3);
    align-items: stretch;
    width: 100%;
  }

  .kds-es__input {
    flex: 1;
    min-width: 0;
    height: 60px;
    padding: 0 var(--kds-s4);
    border: 2px solid var(--kds-black);
    border-radius: var(--kds-radius-pill);
    background-color: var(--kds-cream);
    font-family: var(--kds-font-body);
    font-size: 16px;
    color: var(--kds-black);
    outline: none;
    box-shadow: var(--kds-shadow-sm);
    transition: box-shadow 0.15s ease;
  }

  .kds-es__input::placeholder {
    color: var(--kds-mid-grey);
  }

  .kds-es__input:focus {
    box-shadow: 0 0 0 3px rgba(174, 0, 0, 0.2), var(--kds-shadow-sm);
  }

  .kds-es__submit {
    height: 60px;
    flex-shrink: 0;
    font-size: 16px;
    padding: 0 var(--kds-s6);
  }

  .kds-es__subtext {
    font-family: var(--kds-font-body);
    font-size: 14px;
    margin: 0;
    opacity: 0.85;
  }

  @media (max-width: 767px) {
    .kds-es__container {
      padding: 0 var(--kds-s6);
    }

    .kds-es__row {
      flex-direction: column;
      gap: var(--kds-s2);
    }

    .kds-es__input,
    .kds-es__submit {
      width: 100%;
    }
  }
</style>

<script>
  (function () {
    var params = new URLSearchParams(window.location.search);
    if (params.get('customer_posted') === 'true') {
      var parts = window.location.pathname.split('/');
      parts[parts.length - 1] = '{{ section.settings.success_handle | escape }}';
      window.location.replace(parts.join('/'));
    }
  })();
</script>

{% schema %}
{
  "name": "KDS — Email Signup",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to hide."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email input placeholder",
      "default": "Deine E-Mail-Adresse"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Submit button label",
      "default": "JETZT BEITRETEN"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext below form",
      "info": "Leave blank to hide. e.g. privacy note."
    },
    {
      "type": "header",
      "content": "Form behaviour"
    },
    {
      "type": "text",
      "id": "success_handle",
      "label": "Success page handle",
      "default": "waitlist-success",
      "info": "Page handle to redirect to after signup (without /pages/ prefix)."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#AE0000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#FFFFF5"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext colour",
      "default": "#FFFFF5"
    },
    {
      "type": "range",
      "id": "padding_v",
      "label": "Vertical padding (px)",
      "min": 24,
      "max": 120,
      "step": 8,
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "KDS — Email Signup"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
