      "default": "Custom Info Tiles"
    },
    {
      "id": "subheading",
      "type": "text",
      "label": "Subheading",
      "default": "Share information using custom tiles"
    },
    {
      "type": "checkbox",
      "id": "display_on_card",
      "label": "Display tiles on card background",
      "default": true
    },
    {
