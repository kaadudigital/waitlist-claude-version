{%- comment -%}
  Featured Custom Info Tiles Section
  Displays custom information tiles with image, heading, and description
{%- endcomment -%}

{%- liquid
  if section.settings.image_shape != ''
    assign image_shape = section.settings.image_shape
  else
    assign image_shape = settings.product_tile_media_shape
  endif

  assign mobile_grid_cols = section.settings.tiles_per_row_mobile
  assign layout = section.settings.layout

  case section.settings.tiles_per_row_desktop
    when 2
      assign desktop_grid_cols = 'lg:grid-cols-2'
    when 3
      assign desktop_grid_cols = 'lg:grid-cols-3'
    when 4
      assign desktop_grid_cols = 'lg:grid-cols-4'
    when 5
      assign desktop_grid_cols = 'lg:grid-cols-5'
  endcase

  case section.settings.mobile_slide_width
    when 'three_fifths'
      assign mobile_slide_width = 'w-3/5'
    when 'full_width'
      assign mobile_slide_width = 'w-full'
  endcase

  assign tiles_count = section.blocks.size

  if tiles_count == 1
    assign layout = 'grid'
  endif

  assign eager_loading_limit = mobile_grid_cols | plus: 0 | default: 1

  if layout == 'grid'
    if section.settings.display_on_card
      assign desktop_sizes = 'calc((100vw / ' | append: section.settings.tiles_per_row_desktop | append: ') - 2.5rem)'

      if section.settings.tiles_per_row_mobile == '2'
        assign mobile_sizes = 'calc((100vw / ' | append: section.settings.tiles_per_row_mobile | append: ') - 1.25rem)'
      else
        assign mobile_sizes = 'calc((100vw / ' | append: section.settings.tiles_per_row_mobile | append: ') - 2.5rem)'
      endif
    else
      assign desktop_sizes = 'calc(100vw / ' | append: section.settings.tiles_per_row_desktop | append: ')'
      assign mobile_sizes = 'calc(100vw / ' | append: section.settings.tiles_per_row_mobile | append: ')'
    endif
  else
    if section.settings.display_on_card
      assign desktop_sizes = 'calc(' | append: section.settings.desktop_slide_width | append: 'vw - 2.5rem)'

      if mobile_slide_width == 'w-3/5'
        assign mobile_sizes = 'calc(60vw - 2.5rem)'
      else
        assign mobile_sizes = 'calc(100vw - 2.5rem)'
      endif
    else
      assign desktop_sizes = section.settings.desktop_slide_width | append: 'vw'

      if mobile_slide_width == 'w-3/5'
        assign mobile_sizes = '60vw'
      else
        assign mobile_sizes = '100vw'
      endif
    endif
  endif

  assign sizes = '(min-width: 990px) ' | append: desktop_sizes | append: ', ' | append: mobile_sizes

  assign will_transform = false
  if layout == 'carousel'
    assign will_transform = true
  endif
-%}

{%- comment -%} Generate shape definitions for all tiles {%- endcomment -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'info_tile' -%}
    {%- liquid
      assign tile_shape = image_shape
      if block.settings.image_shape_override != blank
        assign tile_shape = block.settings.image_shape_override
      endif

      assign shape_id = section.id | append: '-' | append: forloop.index0
    -%}
    {%- unless tile_shape == 'default' -%}
      {%- render 'collection-shape-defs', shape: tile_shape, section_id: shape_id, item_count: 1 -%}
    {%- endunless -%}
  {%- endif -%}
{%- endfor -%}

<section
  class="relative overflow-hidden bg-scheme-background text-scheme-text {% if section.settings.use_gradient_background %}bg-scheme-gradient{% endif %}"
  data-color-scheme="{{ section.settings.color_scheme }}"
>
  <div class="section-content relative z-10 py-section-vertical-spacing {% unless layout == 'carousel' %}px-section w-full max-w-site mx-auto{% endunless %}">
    {% if section.settings.title != '' %}
      <h2 class="inline-heading-rte font-heading heading-standard heading-style break-words text-center {{ settings.heading_drop_shadow_style }}">
        {{ section.settings.title }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != '' %}
      <div class="rte mx-auto mt-5 max-w-md text-center">
        {{ section.settings.subheading }}
      </div>
    {%- endif -%}

    <div
      {% if layout == 'carousel' %}
        id="slideshow-{{ section.id }}"
      {% endif %}
      class="{% if section.settings.title != '' %}section-content-top-margin{% endif %} {% if layout == 'carousel' %}splide{% endif %}"
    >
      <div class="{% if layout == 'carousel' %}splide__track overflow-visible {% if settings.product_tiles_scatter %}splide__track--scattered{% endif %} {% if section.settings.display_on_card %}{% if settings.card_shadow_direction contains 'top' %}with-top-card-shadow{% else %}with-bottom-card-shadow{% endif %}{% endif %}{% endif %}">
        <ul class="{% if layout == 'carousel' %}splide__list{% endif %} {% if layout == 'grid' %}grid gap-theme {% if mobile_grid_cols == '2' %}grid-cols-2{% else %}grid-cols-1{% endif %} {{ desktop_grid_cols }}{% endif %}">
          {%- for block in section.blocks -%}
            <li
              class="{% if layout == 'carousel' %}splide__slide {{ mobile_slide_width }}{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- liquid
                if settings.product_tiles_scatter
                  if layout == 'carousel'
                    capture class
                      cycle '-mt-4 ', 'mt-4 '
                    endcapture
                    capture scatter_position
                      cycle 'up', 'down'
                    endcapture
                  else
                    capture class
                      case section.settings.tiles_per_row_mobile
                        when '2'
                          cycle 'max-lg:-mt-4 ', 'max-lg:mt-4 '
                      endcase
                      case section.settings.tiles_per_row_desktop
                        when 3
                          cycle 'lg:mt-4 ', 'lg:-mt-4 ', 'lg:mt-4 '
                        when 2, 4
                          cycle 'lg:-mt-4 ', 'lg:mt-4 '
                        when 5
                          cycle 'lg:mt-4 ', 'lg:-mt-4 ', 'lg:mt-4 ', 'lg:-mt-4 ', 'lg:mt-4 '
                      endcase
                    endcapture
                  endif
                endif

                capture odd_even
                  cycle 'odd', 'even'
                endcapture

                assign tile_shape = image_shape
                if block.settings.image_shape_override != blank
                  assign tile_shape = block.settings.image_shape_override
                endif

                assign shape_id = section.id | append: '-' | append: forloop.index0

                if forloop.index <= eager_loading_limit
                  assign loading = 'eager'
                else
                  assign loading = 'lazy'
                endif
                if forloop.index <= eager_loading_limit
                  assign loading = 'eager'
                else
                  assign loading = 'lazy'
                endif

                if forloop.first
                  assign preload = true
                else
                  assign preload = false
                endif
              -%}

              {%- render 'info-tile',
                block: block,
                crop: section.settings.tiles_aspect_ratio,
                shape: image_shape,
                shape_override: block.settings.image_shape_override,
                shape_id: shape_id,
                display_on_card: section.settings.display_on_card,
                class: class,
                odd_even: odd_even,
                index: forloop.index0,
                tiles_per_row_mobile: section.settings.tiles_per_row_mobile,
                scatter_position: scatter_position,
                loading: loading,
                preload: preload,
                sizes: sizes,
                will_transform: will_transform
              -%}
            </li>
          {%- else -%}
            {%- comment -%} Placeholder when no blocks added {%- endcomment -%}
            {% for i in (1..3) %}
              <li class="{% if layout == 'carousel' %}splide__slide {{ mobile_slide_width }}{% endif %}">
                {%- liquid
                  if settings.product_tiles_scatter
                    if layout == 'carousel'
                      capture class
                        cycle '-translate-y-4 ', 'translate-y-4 '
                      endcapture
                    else
                      capture class
                        case section.settings.tiles_per_row_mobile
                          when '2'
                            cycle 'max-lg:-translate-y-4 ', 'max-lg:translate-y-4 '
                        endcase
                        case section.settings.tiles_per_row_desktop
                          when 3
                            cycle 'lg:translate-y-4 ', 'lg:-translate-y-4 ', 'lg:translate-y-4 '
                          when 2, 4
                            cycle 'lg:-translate-y-4 ', 'lg:translate-y-4 '
                          when 5
                            cycle 'lg:translate-y-4 ', 'lg:-translate-y-4 ', 'lg:translate-y-4 ', 'lg:-translate-y-4 ', 'lg:translate-y-4 '
                        endcase
                      endcapture
                    endif
                  endif
                  capture odd_even
                    cycle 'odd', 'even'
                  endcapture
                  assign tile_shape = image_shape
                  if block.settings.image_shape_override != blank
                    assign tile_shape = block.settings.image_shape_override
                  endif

                  assign shape_id = section.id | append: '-' | append: forloop.index0
                -%}
                {%- render 'info-tile',
                  block: blank,
                  crop: section.settings.tiles_aspect_ratio,
                  shape: image_shape,
                  shape_id: shape_id,
                  display_on_card: section.settings.display_on_card,
                  class: class,
                  odd_even: odd_even,
                  index: forloop.index0,
                  will_transform: will_transform
                -%}
              </li>
            {%- endfor -%}
          {%- endfor -%}
        </ul>
      </div>

      {%- if layout == 'carousel' -%}
        <div class="splide__arrows mt-5 flex items-center justify-center px-section">
          {%- render 'splide-navigation' %}
        </div>
        <script class="slideshow-options" type="application/json">
          {
            "mediaQuery": "min",
            "arrows": true,
            "pagination": false,
            "rewind": true,
            "autoWidth": true,
            "gap": "1.25rem",
            "focus": {{ section.settings.slideshow_focus | json }},
            "type": "loop",
            "autoScroll": {
              "autoStart": {% if section.settings.autoscroll_mode == '0' or section.settings.autoscroll_mode == blank %}false{% else %}true{% endif %},
              "speed": {% if section.settings.autoscroll_mode == blank %}0{% else %}{{ section.settings.autoscroll_mode | plus: 0 | json }}{% endif %}
            },
            "padding": {
              "left": "1.25rem",
              "right": "1.25rem"
            },
            "breakpoints": {
              "990": {
                "gap": "2.5rem",
                "padding": {
                  "left": "2.5rem",
                  "right": "2.5rem"
                }
              }
            }
          }
        </script>
        <style>
          @media (min-width: 990px) {
            #slideshow-{{ section.id }} .splide__slide {
              width: {{ section.settings.desktop_slide_width }}%;
            }
          }
        </style>
      {%- endif -%}
    </div>
  </div>

  {%- liquid
    for block in section.blocks
      case block.type
        when 'background_shape'
          render 'block-background-shape', block: block
        when 'background_pattern'
          render 'block-background-pattern', block: block, scheme: section.settings.color_scheme
      endcase
    endfor
  -%}
</section>

{%- liquid
  assign stickers = section.blocks | where: 'type', 'sticker'
  assign shape_dividers = section.blocks | where: 'type', 'shape_divider'
  for sticker in stickers
    render 'block-sticker', block: sticker
  endfor
  for shape_divider in shape_dividers
    render 'block-shape-divider', block: shape_divider
  endfor
-%}

{% schema %}
{
  "name": "Custom Info Tiles",
