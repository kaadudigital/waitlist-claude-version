{{ 'kaadu-ds.css' | asset_url | stylesheet_tag }}

<div
  class="kds-ticker"
  style="background-color: {{ section.settings.bg_color }};"
  aria-hidden="true"
>
  <div class="kds-ticker__track">
    {%- for i in (1..4) -%}
      <span class="kds-ticker__item" style="color: {{ section.settings.text_color }};">
        {{ section.settings.text }}
      </span>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "KDS — Ticker",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Ticker text",
      "default": "ITS NOT FAIR! ITS NOT FAIR! ITS NOT FAIR! ITS NOT FAIR! "
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#ACFF64"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#AE0000"
    }
  ],
  "presets": [
    {
      "name": "KDS — Ticker"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
