{%- comment -%}
  Section: waitlist-hero
  A self-contained waitlist landing section: hero, email form, and optional ticker.
  Styled entirely from the Kaadu Design System (kaadu-ds.css + kaadu-fonts snippet).

  On successful form submission Shopify appends ?customer_posted=true to the URL.
  The inline script detects this and redirects to the page set in success_handle.
{%- endcomment -%}

{% render 'kaadu-fonts' %}
{{ 'kaadu-ds.css' | asset_url | stylesheet_tag }}

{%- assign has_image = false -%}
{%- if section.settings.product_image != blank -%}
  {%- assign has_image = true -%}
{%- endif -%}

<section
  id="waitlist-hero-{{ section.id }}"
  class="wl-hero{% if has_image %} wl-hero--has-image{% endif %}"
  style="background-color: {{ section.settings.bg_color }};"
>
  <div class="wl-hero__container">

    <div class="wl-hero__content">

      {%- if section.settings.eyebrow != blank -%}
        <p class="wl-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="wl-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.body_text != blank -%}
        <div class="wl-hero__body">{{ section.settings.body_text }}</div>
      {%- endif -%}

      {%- if section.settings.value_prop != blank -%}
        <div class="kds-badge kds-badge--lime wl-hero__badge" aria-label="{{ section.settings.value_prop }}">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" focusable="false">
            <path d="M7 0.5L8.75 5H13.5L9.6 7.75L11.1 12.5L7 9.75L2.9 12.5L4.4 7.75L0.5 5H5.25L7 0.5Z" fill="currentColor"/>
          </svg>
          {{ section.settings.value_prop }}
        </div>
      {%- endif -%}

      <form
        method="post"
        action="/contact#contact_form"
        accept-charset="UTF-8"
        class="wl-hero__form"
        id="waitlist-form-{{ section.id }}"
        novalidate
      >
        <input type="hidden" name="form_type" value="customer">
        <input type="hidden" name="contact[tags]" value="waitlist">
        <input type="hidden" name="utf8" value="✓">

        <div class="wl-hero__form-row">
          <label for="waitlist-email-{{ section.id }}" class="wl-hero__email-label">
            {{ section.settings.email_placeholder }}
          </label>
          <input
            type="email"
            name="contact[email]"
            id="waitlist-email-{{ section.id }}"
            class="wl-hero__email-input"
            placeholder="{{ section.settings.email_placeholder }}"
            autocomplete="email"
            required
          >
          <button type="submit" class="kds-btn kds-btn--display wl-hero__submit">
            {{ section.settings.submit_label }}
          </button>
        </div>

        <div class="wl-hero__form-error" role="alert" aria-live="polite" hidden></div>
      </form>

    </div>

    {%- if has_image -%}
      <div class="wl-hero__media" aria-hidden="true">
        <div class="kds-image-frame wl-hero__image-frame">
          {{-
            section.settings.product_image
            | image_url: width: 600
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              class: 'wl-hero__image',
              alt: ''
          -}}
        </div>
      </div>
    {%- endif -%}

  </div>
</section>

{%- if section.settings.show_ticker -%}
  <div
    class="kds-ticker"
    style="background-color: {{ section.settings.ticker_bg }};"
    aria-hidden="true"
  >
    <div class="kds-ticker__track">
      {%- for i in (1..4) -%}
        <span class="kds-ticker__item" style="color: {{ section.settings.ticker_color }};">
          {{ section.settings.ticker_text }}
        </span>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

<style>
  /* ── Hero layout ──────────────────────────────────────────────────── */
  .wl-hero {
    padding: var(--kds-s16) 0 var(--kds-s12);
  }

  .wl-hero__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--kds-s8);
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--kds-s12);
    align-items: center;
    text-align: center;
  }

  /* Two-column layout when image is present */
  .wl-hero--has-image .wl-hero__container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--kds-s12);
    align-items: center;
    text-align: left;
  }

  /* ── Typography ─────────────────────────────────────────────────── */
  .wl-hero__eyebrow {
    font-family: var(--kds-font-heading);
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--kds-violet);
    margin: 0 0 var(--kds-s3);
  }

  .wl-hero__heading {
    font-family: var(--kds-font-display);
    font-weight: 400;
    font-size: 64px;
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--kds-red);
    letter-spacing: -0.01em;
    margin: 0 0 var(--kds-s6);
  }

  .wl-hero__body {
    font-family: var(--kds-font-body);
    font-size: 18px;
    line-height: 1.56;
    color: var(--kds-black);
    margin: 0 0 var(--kds-s6);
  }

  .wl-hero--has-image .wl-hero__body {
    max-width: 460px;
  }

  /* ── Value prop badge ─────────────────────────────────────────────── */
  .wl-hero__badge {
    display: inline-flex;
    margin-bottom: var(--kds-s8);
  }

  /* ── Email form ───────────────────────────────────────────────────── */
  .wl-hero__email-label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .wl-hero__form-row {
    display: flex;
    gap: var(--kds-s3);
    align-items: stretch;
    max-width: 520px;
  }

  .wl-hero--has-image .wl-hero__form-row {
    max-width: 500px;
  }

  .wl-hero__email-input {
    flex: 1;
    min-width: 0;
    height: 60px;
    padding: 0 var(--kds-s4);
    border: 2px solid var(--kds-black);
    border-radius: var(--kds-radius-pill);
    background-color: var(--kds-cream);
    font-family: var(--kds-font-body);
    font-size: 16px;
    color: var(--kds-black);
    outline: none;
    box-shadow: var(--kds-shadow-sm);
    transition: box-shadow 0.15s ease;
  }

  .wl-hero__email-input::placeholder {
    color: var(--kds-mid-grey);
  }

  .wl-hero__email-input:focus {
    box-shadow: 0 0 0 3px rgba(174, 0, 0, 0.2), var(--kds-shadow-sm);
  }

  .wl-hero__submit {
    height: 60px;
    flex-shrink: 0;
    font-size: 16px;
    padding: 0 var(--kds-s6);
  }

  .wl-hero__form-error {
    margin-top: var(--kds-s3);
    font-family: var(--kds-font-body);
    font-size: 14px;
    color: var(--kds-red);
  }

  /* ── Product image ────────────────────────────────────────────────── */
  .wl-hero__media {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wl-hero__image-frame {
    width: 100%;
    max-width: 480px;
    aspect-ratio: 1 / 1;
    background-color: var(--kds-orange);
  }

  .wl-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Mobile ───────────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .wl-hero {
      padding: var(--kds-s12) 0 var(--kds-s8);
    }

    .wl-hero--has-image .wl-hero__container {
      grid-template-columns: 1fr;
      gap: var(--kds-s8);
      padding: 0 var(--kds-s6);
      text-align: center;
    }

    .wl-hero__container {
      padding: 0 var(--kds-s6);
    }

    /* Image moves above text on mobile */
    .wl-hero__media { order: -1; }

    .wl-hero__heading {
      font-size: 44px;
      line-height: 1.05;
    }

    .wl-hero--has-image .wl-hero__body {
      max-width: 100%;
    }

    .wl-hero__badge {
      margin-left: auto;
      margin-right: auto;
    }

    .wl-hero__form-row,
    .wl-hero--has-image .wl-hero__form-row {
      flex-direction: column;
      max-width: 100%;
      gap: var(--kds-s2);
    }

    .wl-hero__email-input,
    .wl-hero__submit {
      width: 100%;
    }

    .wl-hero__image-frame {
      max-width: 260px;
    }
  }

  /* ── Tablet ───────────────────────────────────────────────────────── */
  @media (min-width: 768px) and (max-width: 989px) {
    .wl-hero__heading { font-size: 52px; }
    .wl-hero--has-image .wl-hero__container { gap: var(--kds-s8); }
  }
</style>

<script>
  (function () {
    var params = new URLSearchParams(window.location.search);
    if (params.get('customer_posted') === 'true') {
      var parts = window.location.pathname.split('/');
      parts[parts.length - 1] = '{{ section.settings.success_handle | escape }}';
      window.location.replace(parts.join('/'));
    }
  })();
</script>

{% schema %}
{
  "name": "Waitlist Hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Gefriergetrocknete Früchte"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "CRUNCH IN PROGRESS!"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body copy",
      "default": "<p><strong>100% Frucht. 0% Ausbeutung.</strong><br><br>Gefriergetrocknete Früchte; fair produziert, in der Ursprungsgemeinde verarbeitet, radikal transparent.</p>"
    },
    {
      "type": "text",
      "id": "value_prop",
      "label": "Value proposition badge",
      "default": "Pioniere profitieren – 50% auf deine erste Bestellung"
    },
    {
      "type": "header",
      "content": "Email form"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Input placeholder",
      "default": "Deine E-Mail-Adresse"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "JETZT BEITRETEN"
    },
    {
      "type": "text",
      "id": "success_handle",
      "label": "Success page handle",
      "default": "waitlist-success",
      "info": "The page handle to redirect to after a successful signup (without /pages/ prefix)."
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFC5FF"
    },
    {
      "type": "header",
      "content": "Ticker strip"
    },
    {
      "type": "checkbox",
      "id": "show_ticker",
      "label": "Show ticker",
      "default": true
    },
    {
      "type": "text",
      "id": "ticker_text",
      "label": "Ticker text",
      "default": "ITS NOT FAIR! ITS NOT FAIR! ITS NOT FAIR! ITS NOT FAIR! "
    },
    {
      "type": "color",
      "id": "ticker_bg",
      "label": "Ticker background",
      "default": "#ACFF64"
    },
    {
      "type": "color",
      "id": "ticker_color",
      "label": "Ticker text color",
      "default": "#AE0000"
    }
  ],
  "presets": [
    {
      "name": "Waitlist Hero"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer", "aside"]
  }
}
{% endschema %}
