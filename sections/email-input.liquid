<!-- Section HTML -->
<div class="email-signup-section">
  <div class="container" style="max-width: {{ section.settings.container_width }}px; margin: 0 auto;">
    {% if section.settings.heading != blank %}
      <h2 class="email-signup-heading" style="color: {{ section.settings.heading_color }}; font-size: {{ section.settings.heading_size }}px; text-align: center; margin-bottom: 30px;">
        {{ section.settings.heading }}
      </h2>
    {% endif %}
    
        <!-- ✅ Wrap everything inside a proper Shopify contact form -->
    <form method="post" action="/contact#contact_form" accept-charset="UTF-8" class="contact-form" id="contact_form">
      <input type="hidden" name="form_type" value="customer">
      <input type="hidden" name="contact[tags]" value="waitlist">
      <input type="hidden" name="utf8" value="✓">

      <div class="email-signup-wrapper">
        <input 
          type="email" 
          name="contact[email]" 
          placeholder="{{ section.settings.placeholder_text }}"
          id="Email"
          class="email-input custom-body-default"
          required
          style="
            flex: 1;
            padding: {{ section.settings.input_padding }}px;
            border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
            border-radius: {{ section.settings.input_border_radius }}px;
            background-color: {{ section.settings.input_background }};
            color: {{ section.settings.input_text_color }};
            height: 60px;
            outline: none;
            box-shadow: none;
          "
        />

        {% if section.settings.use_image_button and section.settings.button_image != blank %}
          <button 
            type="submit"
            class="custom-image-button submit-button"
          >
            <span class="custom-image-span custom-button-text custom-image-button-text">
              {{ section.settings.button_text }}
            </span>
          </button>
        {% else %}
          <button 
            type="submit"
            class="submit-button"
            style=""
          >
            {{ section.settings.button_text }}
          </button>
        {% endif %}
      </div>
      <div class="form-message" style="display: none; text-align: center; margin-top: 15px; padding: 15px; border-radius: 8px;"></div>

    </form>
    <!-- ✅ End Shopify-compatible form -->
    {% if section.settings.subtitle != blank %}
      <p class="email-signup-subtitle" style="color: {{ section.settings.subtitle_color }}; font-size: {{ section.settings.subtitle_size }}px; text-align: center; margin-top: 20px;">
        {{ section.settings.subtitle }}
      </p>
    {% endif %}
  </div>
</div>


<style>
  .email-signup-section {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
  }
  .custom-image-span {
    color: {{ section.settings.button_text_color }}; 
    font-size: {{ section.settings.button_font_size }}px;
    text-shadow: {{ section.settings.text_shadow_x }}px {{ section.settings.text_shadow_y }}px {{ section.settings.text_shadow_blur }}px {{ section.settings.text_shadow_color }};
    transition: color 0.3s ease;
    z-index: 2;
    position: relative;
  }

  .email-signup-wrapper {
    display: flex;
    align-items: center; 
    justify-content: center;
    gap: 20px;
    max-width: 600px;
    margin: 0 auto;
  }


  .custom-image-button {
      background-image: url('{{ section.settings.button_image | img_url: 'master' }}');
      background-size: {{ section.settings.image_fit }};
      background-position: center;
      background-repeat: no-repeat;
      background-color: {{ section.settings.button_background }};
      border: none;
      cursor: pointer;
      height: {{ section.settings.button_height }}px;
      min-width: {{ section.settings.button_width }}px;
      width: {{ section.settings.button_width }}px;
      transition: all 0.3s ease;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      filter: hue-rotate({{ section.settings.image_hue_rotate }}deg) saturate({{ section.settings.image_saturation }}%) brightness({{ section.settings.image_brightness }}%);
  }

  .submit-button {
      background-color: {{ section.settings.button_background }};
      color: {{ section.settings.button_text_color }};
      border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }};
      border-radius: {{ section.settings.button_border_radius }}px;
      padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
      font-size: {{ section.settings.button_font_size }}px;
      cursor: pointer;
      height: 60px;
      min-width: 140px;
      transition: all 0.3s ease;
  }


  .email-input::placeholder {
    color: {{ section.settings.placeholder_color }};
  }
  
  .email-input:focus {
    border-color: {{ section.settings.input_focus_border }};
    box-shadow: 0 0 0 2px {{ section.settings.input_focus_border }}33;
  }
  
  .custom-image-button {
    overflow: hidden;
  }
  
  @media (max-width: 768px) {

  


  }
</style>

<script>
    // Show success message after form submission
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('customer_posted') === 'true') {
    const pathParts = window.location.pathname.split('/');
    pathParts[pathParts.length - 1] = 'waitlist-success';
    window.location.replace(pathParts.join('/'));
  }
    
</script>
  {%- liquid
    for block in section.blocks
      case block.type
        when 'background_shape'
          render 'block-background-shape', block: block
        when 'background_pattern'
          render 'block-background-pattern', block: block, scheme: section.settings.color_scheme
      endcase
    endfor
  -%}

{%- liquid
  assign stickers = section.blocks | where: 'type', 'sticker'
  assign shape_dividers = section.blocks | where: 'type', 'shape_divider'
  for sticker in stickers
    render 'block-sticker', block: sticker
  endfor
  for shape_divider in shape_dividers
    render 'block-shape-divider', block: shape_divider
  endfor
-%}
